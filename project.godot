; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows this.
;
; Format:
;   [section] ; section goes with spaces
;   param=value ; lower_case with underscores
;
; Multiline values can be written by hand
; but must always begin with "key="
; and end with nothing or a comment

config_version=5

[application]

config/name="Operation Quiet Window"
config/description="A 2D narrative-stealth puzzle game. You are an unauthorized process disguised as a red browser window, infiltrating an authoritarian government's public website to steal classified intel."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")

[autoload]

GameState="*res://scripts/GameState.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=false

[rendering]

renderer/rendering_method="forward_plus"
